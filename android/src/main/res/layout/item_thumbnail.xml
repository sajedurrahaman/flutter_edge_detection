<?xml version="1.0" encoding="utf-8"?>
<!--
    item_thumbnail.xml
    Each captured-image thumbnail shown in the horizontal strip.
-->
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="64dp"
    android:layout_height="64dp"
    android:layout_marginEnd="6dp"
    android:layout_marginTop="8dp"
    android:layout_marginBottom="8dp">

    <!-- Thumbnail image -->
    <ImageView
        android:id="@+id/thumbnail_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:background="#333333"
        android:contentDescription="Captured image thumbnail" />

    <!-- Rounded border overlay so thumbnails look polished -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/thumbnail_border" />

</FrameLayout>